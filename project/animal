#!/usr/bin/env python3
import argparse

def main():
    parser = argparse.ArgumentParser(description="Simulate the sounds of various farm animals. Supports customizing the number of repetitions and loudness.")
    subparsers = parser.add_subparsers(dest="animal", required=True, help="Supported animals")

    animals = {
        "cow": "moo",
        "pig": "oink",
        "duck": "quack",
        "horse": "neigh",
        "fox": "???"
    }

    for animal_name in animals:
        animal_parser = subparsers.add_parser(animal_name, help=f"Print sounds for {animal_name}")
        animal_parser.add_argument("-n", "--number", type=int, default=3, help="How many times to print the word (default: 3)")
        animal_parser.add_argument("-l", "--loud", action="store_true", help="Make the output in capital letters")

    args = parser.parse_args()

    sound = animals[args.animal]
    if args.loud:
        sound = sound.upper()

    print(" ".join([sound] * args.number))

if __name__ == "__main__":
    main()